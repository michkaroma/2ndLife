# ─── Accès ───────────────────────────────────────────────────────────────────
# Mot de passe unique pour protéger l'accès public à l'application.
APP_PASSWORD=change-moi

# Secret pour signer le cookie de session (chaîne aléatoire longue, ex: openssl rand -hex 32).
SESSION_SECRET=change-moi-une-longue-chaine-aleatoire

# ─── Web Push (notifications) ──────────────────────────────────────────────────
# Générer la paire de clés avec :  npm run vapid
VAPID_PUBLIC=
VAPID_PRIVATE=
VAPID_SUBJECT=mailto:toi@exemple.fr

# Heure du rappel quotidien au format HH:MM (24h). Optionnel.
PUSH_TIME=20:00

# ─── Serveur (production, adapter-node) ────────────────────────────────────────
# URL publique de l'application (requise par adapter-node derrière un reverse proxy).
ORIGIN=http://localhost:3000
# PORT=3000
# HOST=0.0.0.0

# ─── Base de données ───────────────────────────────────────────────────────────
# Chemin du fichier SQLite (optionnel ; défaut : data/habitquest.db).
# DATABASE_PATH=data/habitquest.db
